<div style="max-width: 800px; margin: 0 auto; padding: 20px; font-family: sans-serif; line-height: 1.6;">
    
    <header style="border-bottom: 2px solid #333; margin-bottom: 40px; padding-bottom: 20px; text-align: center;">
        <h1 style="font-size: 2.5rem; color: #2c3e50;">{{title}}</h1>
        <p style="color: #666;">Resenhas e novidades do mundo literário</p>
    </header>

    <main>
        {{#each posts}}
            <article style="margin-bottom: 50px; padding-bottom: 30px; border-bottom: 1px solid #eee;">
                <span style="color: #e74c3c; font-weight: bold; font-size: 0.8rem; text-transform: uppercase;">
                    {{this.categoria}}
                </span>
                
                <h2 style="margin: 10px 0;">
                    <a href="/post/{{this.id}}" style="text-decoration: none; color: #2c3e50;">{{this.titulo}}</a>
                </h2>
                
                <p style="color: #888; font-size: 0.9rem; margin-bottom: 15px;">Postado em: {{this.data}}</p>
                
                <p style="font-size: 1.1rem; color: #444;">
                    {{this.resumo}}
                </p>

                <div style="margin-top: 20px;">
                    <a href="/post/{{this.id}}" style="background: #2c3e50; color: white; padding: 8px 16px; text-decoration: none; border-radius: 4px; font-size: 0.9rem;">
                        Ler texto completo
                    </a>
                </div>
            </article>
        {{/each}}
    </main>

    <footer style="text-align: center; margin-top: 50px; color: #999; font-size: 0.8rem;">