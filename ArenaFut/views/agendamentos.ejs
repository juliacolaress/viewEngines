<!DOCTYPE html>
<html>
<head>
    <title><%= titulo %></title>
    <link rel='stylesheet' href='/stylesheets/style.css' />
</head>
<body>
    <header>
        <h1>Confirmar <span>Reserva</span></h1>
        <p>Você selecionou o horário das <strong><%= horario %></strong></p>
    </header>

    <main class="container">
        <div class="card" style="max-width: 400px; margin: 0 auto; border-top: 5px solid var(--primary);">
            <h3>Dados do Jogador</h3>
            <form action="/confirmar" method="POST" style="display: flex; flex-direction: column; gap: 1rem; text-align: left;">
                <input type="hidden" name="horario" value="<%= horario %>">
                
                <label>Nome Completo:</label>
                <input type="text" name="nome" placeholder="Ex: Giba do Vôlei" required style="padding: 10px; border-radius: 5px; border: 1px solid #ddd;">
                
                <label>Telefone:</label>
                <input type="tel" name="telefone" placeholder="(00) 00000-0000" required style="padding: 10px; border-radius: 5px; border: 1px solid #ddd;">

                <button type="submit" class="btn-reservar" style="margin-top: 10px;">Finalizar Agendamento</button>
                <a href="/" style="text-align: center; color: var(--danger); font-size: 0.8rem;">Cancelar</a>
            </form>
        </div>
        <input type="hidden" name="horario" value="<%= horario %>">
    </main>
</body>
</html>